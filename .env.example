# Скопируйте в .env и заполните значения
TELEGRAM_BOT_TOKEN=
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_LANGUAGE=en
BATCH_SIZE=30
UNDER_RATED_THRESHOLD=10
AI_GENERATION_BATCH_SIZE=10
AI_GENERATION_MIN_AVAILABLE=10

# Локально: polling (по умолчанию)
BOT_MODE=polling

# Railway / production
# BOT_MODE=webhook
# WEBHOOK_SECRET=случайная_строка_32_символа
# RAILWAY_PUBLIC_DOMAIN задаётся Railway автоматически
# или явно: WEBHOOK_URL=https://your-app.up.railway.app/webhook
